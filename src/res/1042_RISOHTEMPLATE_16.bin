{
    BLOCK "StringFileInfo"
    {
        BLOCK "041203B5" // ko_KR, Korea (KS C 5601)
        {
            VALUE "CompanyName", "우리 회사"
            VALUE "FileDescription", "내 지원서"
            VALUE "FileVersion", "0.0"
            VALUE "LegalCopyright", "Copyright © 2026 우리 회사"
            VALUE "ProductName", "내 지원서"
            VALUE "ProductVersion", "0.0"
        }
    }
    BLOCK "VarFileInfo"
    {
        VALUE "Translation", 0x0412, 0x03B5
    }
}
