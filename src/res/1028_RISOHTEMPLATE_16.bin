            VALUE "LegalCopyright", "Copyright (C) 2026 我的公司"
            VALUE "ProductName", "我的軟體"
            VALUE "ProductVersion", "0.0"
        }
    }
    BLOCK "VarFileInfo"
    {
        VALUE "Translation", 0x0804, 0x04B0
    }
}
