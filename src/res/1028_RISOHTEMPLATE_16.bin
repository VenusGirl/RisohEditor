1 VERSIONINFO
FILEVERSION     0, 0, 0, 0
PRODUCTVERSION  0, 0, 0, 0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
{
    BLOCK "StringFileInfo"
    {
        BLOCK "040403B6" // zh_TW, Taiwan (Big5)
        {
            VALUE "CompanyName", "我的公司"
            VALUE "FileDescription", "我的軟體"
            VALUE "FileVersion", "0.0"
            VALUE "LegalCopyright", "Copyright © 2026 我的公司"
            VALUE "ProductName", "我的軟體"
            VALUE "ProductVersion", "0.0"
        }
    }
    BLOCK "VarFileInfo"
    {
        VALUE "Translation", 0x0404, 0x03B6
    }
}
