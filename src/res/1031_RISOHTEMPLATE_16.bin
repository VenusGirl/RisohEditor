1 VERSIONINFO
FILEVERSION     0, 0, 0, 0
PRODUCTVERSION  0, 0, 0, 0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
{
    BLOCK "StringFileInfo"
    {
        BLOCK "040704E4" // de_DE, Multilingual
        {
            VALUE "CompanyName", "Mein Unternehmen"
            VALUE "FileDescription", "Meine Bewerbung"
            VALUE "FileVersion", "0.0"
            VALUE "LegalCopyright", "Copyright © 2026 Mein Unternehmen"
            VALUE "ProductName", "Meine Bewerbung"
            VALUE "ProductVersion", "0.0"
        }
    }
    BLOCK "VarFileInfo"
    {
        VALUE "Translation", 0x0407, 0x04E4
    }
}
