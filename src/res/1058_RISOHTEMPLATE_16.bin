1 VERSIONINFO
FILEVERSION     0, 0, 0, 0
PRODUCTVERSION  0, 0, 0, 0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
{
    BLOCK "StringFileInfo"
    {
        BLOCK "042204E3" // uk_UA, Cyrillic
        {
            VALUE "CompanyName", "Моя компанія"
            VALUE "FileDescription", "Моя заявка"
            VALUE "FileVersion", "0.0"
            VALUE "LegalCopyright", "Copyright © 2026 Моя компанія"
            VALUE "ProductName", "Моя заявка"
            VALUE "ProductVersion", "0.0"
        }
    }
    BLOCK "VarFileInfo"
    {
        VALUE "Translation", 0x0422, 0x04E3
    }
}
