1 VERSIONINFO
FILEVERSION     0, 0, 0, 0
PRODUCTVERSION  0, 0, 0, 0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
{
    BLOCK "StringFileInfo"
    {
        BLOCK "0C0A04E4" // es_ES, Multilingual
        {
            VALUE "CompanyName", "Mi Empresa"
            VALUE "FileDescription", "Mi Solicitud"
            VALUE "FileVersion", "0.0"
            VALUE "LegalCopyright", "Copyright © 2026 Mi Empresa"
            VALUE "ProductName", "Mi Solicitud"
            VALUE "ProductVersion", "0.0"
        }
    }
    BLOCK "VarFileInfo"
    {
        VALUE "Translation", 0x0C0A, 0x04E4
    }
}
