1 VERSIONINFO
FILEVERSION     0, 0, 0, 0
PRODUCTVERSION  0, 0, 0, 0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
{
    BLOCK "StringFileInfo"
    {
        BLOCK "040C04E4"
        {
            VALUE "CompanyName", "Mon Entreprise"
            VALUE "FileDescription", "Ma Candidature"
            VALUE "FileVersion", "0.0"
            VALUE "LegalCopyright", "Copyright © 2026 Mon Entreprise"
            VALUE "ProductName", "Ma Candidature"
            VALUE "ProductVersion", "0.0"
        }
    }
    BLOCK "VarFileInfo"
    {
        VALUE "Translation", 0x040C, 0x04E4
    }
}
