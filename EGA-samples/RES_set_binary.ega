@ Add an Japanese (1041) RT_HTML (23) resource of name 1.
RES_set_binary(23, 1, 1041,
    binary(
        "<html><head>", 10,
        "<title>これはテストです。</title>", 10,
        "</head>", 10,
        "<body>", 10,
        "これはテストです。", 10,
        "</body></html>", 10
    )
);

@ Select it.
RES_select(23, 1, 1041);
